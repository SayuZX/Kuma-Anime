# Kuma Anime — environment configuration
#
# The app talks directly to free public APIs (Jikan, AniList, Kitsu, MangaDex)
# and needs NO secret keys or private proxy URLs to run. Copy this file to
# `.env.local` to override defaults.

# Logging verbosity for the built-in logger: debug | info | warn | error | silent
# Defaults to "debug" in development and "warn" in production.
NEXT_PUBLIC_LOG_LEVEL=warn

# ---------------------------------------------------------------------------
# OPTIONAL — external anime streaming provider (OFF by default)
# ---------------------------------------------------------------------------
# The official free APIs above are METADATA ONLY and do NOT provide video.
# Leave this blank to keep the app metadata-first (the watch page shows info +
# an "unavailable" notice).
#
# If you (the operator) choose to self-host an unofficial streaming API, set
# its base URL here. See docs/STREAMING.md for the exact request/response
# contract, the subtitle-priority behaviour, and the important legal warning.
#
# NEXT_PUBLIC_STREAM_API_URL=https://your-stream-api.example.com
NEXT_PUBLIC_STREAM_API_URL=
