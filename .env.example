# Kuma Anime — environment configuration
#
# Metadata (titles, images, schedules, characters) comes from free public APIs
# (Jikan, AniList, Kitsu, MangaDex) and needs NO keys. Copy this file to
# `.env.local` to override defaults.

# Logging verbosity for the built-in logger: debug | info | warn | error | silent
# Defaults to "debug" in development and "warn" in production.
NEXT_PUBLIC_LOG_LEVEL=warn

# ---------------------------------------------------------------------------
# Anime streaming provider (Otakudesu — Sub Indo)
# ---------------------------------------------------------------------------
# The watch page pulls episodes and video from a wajik-anime-api compatible
# instance (Otakudesu source, Indonesian subtitles). It defaults to the public
# demo below, so streaming works out of the box.
#
# Public demos are shared and can be rate-limited or go down. For reliability,
# deploy your own wajik-anime-api instance (one-click deploy on its repo) and
# put its URL here. See docs/STREAMING.md.
#
# NEXT_PUBLIC_STREAM_API_URL=https://wajik-anime-api.vercel.app
NEXT_PUBLIC_STREAM_API_URL=
